{
  "manifest_version": 3,
  "name": "GestureNet Extension",
  "version": "1.0",
  "description": "Control web pages with hand gestures",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GestureNet"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["monitoring.html", "monitoring.js", "icons/*", "lib/*", "lib/wasm/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
